root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = off

# YAML spec disallows tabs.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown: keep tabs but be lenient about trailing whitespace (used for line breaks).
[*.md]
trim_trailing_whitespace = false
